CLOUD_SQL_CONNECTION_NAME=

# Host must match the compose service name `cloud-sql-proxy` (not localhost).
# Use your Cloud SQL user, password, and database name for exam-tools.
DATABASE_URL=postgresql+asyncpg://exam_tools_user:YOUR_PASSWORD@cloud-sql-proxy:5432/exam_tools_db


SECRET_KEY=
ENVIRONMENT=staging

# Browser origins for CORS (every HTTPS origin that serves the SPA).
# Accepted formats:
# - CSV (recommended): list each frontend URL (API origin only if needed).
# - JSON array: ["https://monitoring.jamesyin.com","https://monitoring.ctvet.gov.gh"]
CORS_ORIGINS=https://monitoring.jamesyin.com,https://monitoring.ctvet.gov.gh

# Super admin created on first start if missing (required for initial login)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me
SUPER_ADMIN_FULL_NAME=Super Admin

# Logging (APP_ prefix for LoggingSettings in app/config.py)
APP_ENV=staging
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=json


STORAGE_BACKEND=gcs
GCS_BUCKET_NAME=your-project-exam-tools-staging-files
GCS_PROJECT_ID=your-gcp-project
# VM service account uses ADC; set only if using a key file inside the container:
# GCS_CREDENTIALS_PATH=/path/to/service-account.json
# Prefix for objects in the bucket (no leading slash):
# GCS_DOCUMENTS_PREFIX=exam-tools/documents

# --- Frontend: compose omits NEXT_PUBLIC_API_BASE_URL so the browser derives
# monitoring-api.<same-parent-domain> (see frontend/lib/auth.ts). The frontend
# container sets INTERNAL_API_BASE_URL to the compose service for any SSR.
# To force a single public API host at build time, add a build arg in
# compose.staging.gcp.yaml: NEXT_PUBLIC_API_BASE_URL=https://monitoring-api.jamesyin.com

# --- Optional: deploy.sh health-check domains (defaults match traefik/dynamic.staging.yml) ---
# STAGING_FRONTEND_DOMAIN=monitoring.jamesyin.com
# STAGING_API_DOMAIN=monitoring-api.jamesyin.com
